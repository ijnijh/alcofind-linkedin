# Streamlit Secrets 예시 — 이 파일을 secrets.toml로 복사 후 값 채우기
#
# 로컬 개발: app/.streamlit/secrets.toml 에 저장 (gitignore됨)
# 클라우드:  Streamlit Cloud 콘솔 → App settings → Secrets 에 동일 내용 붙여넣기
#
# secrets.toml 파일은 절대 git에 커밋하지 마세요.

# Anthropic API (필수)
ANTHROPIC_API_KEY = "sk-ant-api03-여기에본인키"

# 앱 접근 비밀번호 (본인만 알도록 임의 문자열)
APP_PASSWORD = "여기에원하는비밀번호"

# Unsplash API (선택) — Photo 카드 템플릿용. 없으면 Bold Hook으로 fallback
# 발급: https://unsplash.com/developers → Your apps → New Application
UNSPLASH_ACCESS_KEY = "여기에_Unsplash_Access_Key"
